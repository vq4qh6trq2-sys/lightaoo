import { NextRequest, NextResponse } from 'next/server'
import mammoth from 'mammoth'
import * as XLSX from 'xlsx'
import Fuse from 'fuse.js'

export const runtime = 'nodejs'
export const maxDuration = 60

export async function POST(req: NextRequest) {
  const formData = await req.formData()
  const cctpFile = formData.get('cctp') as File
  const dpgfFile = formData.get('dpgf') as File

  // 1. Parse CCTP
  const cctpBuffer = Buffer.from(await cctpFile.arrayBuffer())
  const cctpText = (await mammoth.extractRawText({ buffer: cctpBuffer })).value
  const cctpArticles = cctpText.split('\n')
  .filter(l => l.match(/^\d+\.\d+|^\d+\.\d+\.\d+/))
  .map(l => l.trim())

  // 2. Parse DPGF
  const dpgfBuffer = await dpgfFile.arrayBuffer()
  const wb = XLSX.read(dpgfBuffer, { type: 'array', cellFormula: true, cellStyles: true })
  const ws = wb.Sheets[wb.SheetNames[0]]
  const dpgfRows: any[] = XLSX.utils.sheet_to_json(ws, { header: 1 })

  // 3. Matching fuzzy sur colonne C description
  const dpgfDesc = dpgfRows.map((row, idx) => ({ desc: row[2] || '', idx }))
  const fuse = new Fuse(dpgfDesc, { keys: ['desc'], threshold: 0.4 })
  const matches: number[] = []

  cctpArticles.forEach(art => {
    const res = fuse.search(art)
    if (res.length > 0) matches.push(res[0].item.idx)
  })

  // 4. Surligne vert les lignes matchées
  matches.forEach(rowIdx => {
    for (let c = 0; c < 10; c++) {
      const cellAddr = XLSX.utils.encode_cell({ r: rowIdx, c })
      if (!ws[cellAddr]) ws[cellAddr] = { t: 's', v: '' }
      ws[cellAddr].s = { fill: { fgColor: { rgb: "C6EFCE" } } }
    }
  })

  // 5. Renvoie l’Excel
  const outBuffer = XLSX.write(wb, { type: 'buffer', bookType: 'xlsx', cellStyles: true })
  return new NextResponse(outBuffer, {
    headers: {
      'Content-Type': 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
      'Content-Disposition': 'attachment; filename="DPGF_matche.xlsx"'
    }
  })
}